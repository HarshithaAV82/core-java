# Ignore IntelliJ files
.idea/
*.iml

# Ignore build/output folders
out/
build/

# Ignore logs
*.log

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore compiled Java files
*.class

# (Optional) Ignore jar/war if generated
*.jar
*.war

# Ignore everything EXCEPT src (important trick)
*
!src/
!src/**

# Also allow gitignore itself
!.gitignore